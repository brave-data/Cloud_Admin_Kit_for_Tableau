# =============================================================
# ⚠️  このファイル (.env.example) は Git で管理されています。
#     ここに実際の認証情報を書かないでください。
#
#     ✅ 正しい手順:
#        cp .env.example .env   ← .env に値を書く（Git管理外）
# =============================================================

# Tableau Cloud のホスト名 (https:// は不要)
# 例: 10ay.online.tableau.com
TABLEAU_SERVER_URL=https://your-server.online.tableau.com

# サイト名 (Content URL)
# 例: mycompany  ※ デフォルトサイトは空欄のまま
TABLEAU_SITE_NAME=

# Personal Access Token
# Tableau Cloud の「アカウント設定 > Personal Access Tokens」で作成
TABLEAU_TOKEN_NAME=your-token-name
TABLEAU_TOKEN_SECRET=your-token-secret

# SSL証明書の検証 (デフォルト: true)
# 社内プロキシ環境で SSLError が出る場合のみ false に変更してください。
# ⚠️ false にするとセキュリティが低下します。本番環境での使用は非推奨です。
# SSL_VERIFY=false

# サーバー起動ポート (デフォルト: 8000)
PORT=8000

# サーバーのバインドアドレス (デフォルト: 127.0.0.1 = ローカルのみ)
# LAN 内の他の端末からアクセスさせたい場合のみ 0.0.0.0 に変更してください。
# ⚠️ このアプリは認証なしで管理情報を返します。0.0.0.0 での公開は注意が必要です。
# HOST=0.0.0.0
