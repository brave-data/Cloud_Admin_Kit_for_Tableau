# Tableau Cloud 接続設定
# このファイルを .env にコピーして値を入力してください
# cp .env.example .env

# Tableau Cloud のホスト名 (https:// は不要)
# 例: 10ay.online.tableau.com
TABLEAU_SERVER_URL=https://your-server.online.tableau.com

# サイト名 (Content URL)
# 例: mycompany  ※ デフォルトサイトは空欄のまま
TABLEAU_SITE_NAME=

# Personal Access Token
# Tableau Cloud の「アカウント設定 > Personal Access Tokens」で作成
TABLEAU_TOKEN_NAME=your-token-name
TABLEAU_TOKEN_SECRET=your-token-secret

# サーバー起動ポート (デフォルト: 8000)
PORT=8000
